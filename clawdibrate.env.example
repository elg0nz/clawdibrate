# Copy to .clawdibrate/env (mkdir -p .clawdibrate first).
# That path is gitignored with the rest of .clawdibrate/ but is loaded by
# python -m clawdibrate before resolving CLAWDIBRATE_AGENT — so IDE tasks and
# non-login shells pick up the agent without exporting in ~/.zshrc.

CLAWDIBRATE_AGENT=cursor
